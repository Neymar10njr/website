# Copy this to .env and fill in real values for production.
# Never commit .env to git.

# Set to "production" when deploying publicly. Anything else uses dev defaults.
FLASK_ENV=production

# Public domain hosting the frontend (used for CORS + Caddy TLS).
# Use a comma-separated list to allow multiple origins.
PUBLIC_DOMAIN=treknest.example.com
ALLOWED_ORIGINS=https://treknest.example.com

# How browsers reach the backend. Usually the same domain as the frontend
# because Caddy proxies /api and /static to it.
PUBLIC_BACKEND_URL=https://treknest.example.com

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_secrets.token_hex(32)
JWT_SECRET_KEY=replace_me_with_secrets.token_hex(32)

# Postgres
POSTGRES_USER=treknest
POSTGRES_PASSWORD=replace_me_with_strong_random_password
POSTGRES_DB=treknest
DATABASE_URI=postgresql+psycopg2://treknest:replace_me_with_strong_random_password@db:5432/treknest

# Email (used for verification + password reset). Leave SMTP_HOST empty to log to stdout instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@treknest.example.com
SMTP_USE_TLS=true

# Optional: Sentry for error monitoring. Leave empty to disable.
SENTRY_DSN=

# Optional: S3-compatible image storage. Leave AWS_S3_BUCKET empty to use local volume.
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=

# Email used by Caddy to register Let's Encrypt certificates
ACME_EMAIL=admin@example.com

# Rate limiting
RATELIMIT_STORAGE_URI=memory://
